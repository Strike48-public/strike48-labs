---
/**
 * Generates breadcrumbs from the current URL path and sidebar config.
 * Displayed above the page title on doc pages.
 */

const currentPath = Astro.url.pathname;
const segments = currentPath.split('/').filter(Boolean);

// Build breadcrumb items from URL segments
interface Crumb {
  label: string;
  href: string;
}

const labelMap: Record<string, string> = {
  'overview': 'Overview',
  'architecture': 'Architecture',
  'prospector-studio': 'Prospector Studio',
  'strikehub': 'StrikeHub',
  'kubestudio': 'KubeStudio',
  'pick': 'Pick',
  'developers': 'Developers',
  'sdk-rs': 'SDK for Rust',
  'strikekit': 'StrikeKit',
  'shared': 'Resources',
  'contributing': 'Contributing',
  'media': 'Demos & Media',
  'guides': 'Guides',
  'help': 'Help',
  'getting-started': 'Getting Started',
  'graphql-api': 'GraphQL API',
  'faq': 'FAQ',
  'troubleshooting': 'Troubleshooting',
  'installation': 'Installation',
  'configuration': 'Configuration',
  'quick-start': 'Quick Start',
  'connectors': 'Connectors',
  'agents': 'Agents',
  'workflows': 'Workflows',
  'knowledge-bases': 'Knowledge Bases',
  'mcp-servers': 'MCP Servers',
  'marketplace': 'Tools',
  'debugging': 'Debug Logging',
  'connectivity': 'Connectivity',
  'authentication': 'Authentication',
  'ui-rendering': 'UI & Rendering',
  'cluster-management': 'Cluster Management',
  'deployments': 'Deployments',
  'cluster-connectivity': 'Cluster Connectivity',
  'permissions': 'Permissions & RBAC',
  'workload-issues': 'Workload Issues',
  'privileges': 'Privileges',
  'network-tools': 'Network Tools',
  'remote-execution': 'Remote Execution',
  'building-your-first-connector': 'Building Your First Connector',
  'testing-connectors': 'Testing Connectors',
  'error-handling': 'Error Handling',
  'async-patterns': 'Async Patterns',
  'deployment': 'Deployment',
  'gif-guidelines': 'GIF Guidelines',
  'gif-workflow': 'GIF Workflow',
  'vhs-examples': 'VHS Examples',
};

function formatLabel(segment: string): string {
  return labelMap[segment] || segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

const crumbs: Crumb[] = [
  { label: 'Docs', href: '/overview/' },
];

let accumulated = '';
for (let i = 0; i < segments.length; i++) {
  accumulated += '/' + segments[i];
  const isLast = i === segments.length - 1;
  crumbs.push({
    label: formatLabel(segments[i]),
    href: isLast ? '' : accumulated + '/',
  });
}
---

{crumbs.length > 1 && (
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      {crumbs.map((crumb, i) => (
        <li>
          {i > 0 && (
            <svg class="breadcrumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          )}
          {crumb.href ? (
            <a href={crumb.href}>{crumb.label}</a>
          ) : (
            <span aria-current="page">{crumb.label}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .breadcrumbs {
    margin-bottom: 0.75rem;
  }

  ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    line-height: 1;
  }

  a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--sl-color-accent);
  }

  span[aria-current='page'] {
    color: var(--sl-color-white);
    font-weight: 500;
  }

  .breadcrumb-sep {
    color: var(--sl-color-gray-4);
    margin: 0 0.25rem;
    flex-shrink: 0;
  }
</style>
