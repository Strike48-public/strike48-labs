---
import LucideIcon from "./LucideIcon.astro";

interface Feature {
  iconName: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<section class="bg-base-300 py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-base-content mb-12">Built for Increasing Productivity</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="card bg-base-200/50 border border-base-content/5">
          <div class="card-body items-center text-center gap-3">
            <div class="text-primary">
              <LucideIcon name={f.iconName} size={28} />
            </div>
            <h3 class="card-title text-base text-base-content">{f.title}</h3>
            <p class="text-base-content/60 text-sm leading-relaxed">{f.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
