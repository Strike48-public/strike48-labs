---
import LucideIcon from "./LucideIcon.astro";

interface Feature {
  iconName: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<section class="features-section">
  <h2>Built for Increasing Productivity</h2>
  <div class="features-grid">
    {features.map((f) => (
      <div class="feature-item">
        <div class="feature-icon">
          <LucideIcon name={f.iconName} size={28} />
        </div>
        <h3>{f.title}</h3>
        <p>{f.description}</p>
      </div>
    ))}
  </div>
</section>
