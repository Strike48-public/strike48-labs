---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  repo: string;
  label?: string;
}

const { repo, label = "Download from GitHub" } = Astro.props;
const href = `https://github.com/Strike48-public/${repo}/releases`;
---

<a href={href} class="gh-btn" target="_blank" rel="noopener noreferrer">
  <span class="gh-btn-icon">
    <LucideIcon name="github" size={18} />
  </span>
  <span class="gh-btn-label">{label}</span>
  <span class="gh-btn-arrow">
    <LucideIcon name="external-link" size={14} />
  </span>
</a>

<style>
  .gh-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.5rem;
    margin: 0.75rem 0 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    color: #fff;
    background: #24292f;
    border-radius: 0.5rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gh-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.08) 45%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.08) 55%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gh-btn:hover {
    transform: translateY(-1px);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .gh-btn:hover::before {
    transform: translateX(100%);
  }

  .gh-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .gh-btn-icon {
    display: flex;
    align-items: center;
    opacity: 0.9;
  }

  .gh-btn-label {
    position: relative;
    z-index: 1;
  }

  .gh-btn-arrow {
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .gh-btn:hover .gh-btn-arrow {
    opacity: 0.7;
    transform: translateX(0);
  }

  :root[data-theme="dark"] .gh-btn {
    background: #1c2128;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  :root[data-theme="dark"] .gh-btn:hover {
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  @media (prefers-reduced-motion: reduce) {
    .gh-btn,
    .gh-btn::before,
    .gh-btn-arrow {
      transition: none !important;
      transform: none !important;
    }

    .gh-btn-arrow {
      opacity: 0.7;
    }
  }
</style>
