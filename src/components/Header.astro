---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Docs', href: '/overview/' },
  { label: 'User Apps', href: '/strikehub/' },
  { label: 'Developers', href: '/developers/sdk-rs/' },
  { label: 'Resources', href: '/shared/faq/' },
];

function isActive(href: string): boolean {
  if (href === '/overview/') {
    return currentPath === '/overview/' || currentPath === '/architecture/';
  }
  if (href === '/strikehub/') {
    return ['/strikehub/', '/prospector-studio/', '/kubestudio/', '/pick/'].some(p => currentPath.startsWith(p));
  }
  if (href === '/developers/sdk-rs/') {
    return currentPath.startsWith('/developers/');
  }
  if (href === '/shared/faq/') {
    return currentPath.startsWith('/shared/') || currentPath.startsWith('/media') || currentPath.startsWith('/contributing/');
  }
  return false;
}
---

<div class="header sl-header-custom">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="sl-hidden md:sl-flex gap-1 items-center" aria-label="Main navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'btn btn-ghost btn-sm text-sm font-medium no-underline whitespace-nowrap',
          isActive(link.href) ? 'bg-base-content/10 text-base-content' : 'text-base-content/70'
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style>
  .sl-header-custom {
    display: flex;
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    overflow: visible !important;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
  }
</style>
