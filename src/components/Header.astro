---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Docs', href: '/overview/' },
  { label: 'User Apps', href: '/strikehub/' },
  { label: 'Developers', href: '/developers/sdk-rs/' },
  { label: 'Resources', href: '/contributing/gif-guidelines/' },
];

function isActive(href: string): boolean {
  if (href === '/overview/') {
    return currentPath === '/overview/' || currentPath === '/architecture/';
  }
  if (href === '/strikehub/') {
    return ['/strikehub/', '/prospector-studio/', '/kubestudio/', '/pick/'].some(p => currentPath.startsWith(p));
  }
  if (href === '/developers/sdk-rs/') {
    return currentPath.startsWith('/developers/');
  }
  if (href === '/contributing/gif-guidelines/') {
    return currentPath.startsWith('/shared/') || currentPath.startsWith('/media') || currentPath.startsWith('/contributing/');
  }
  return false;
}
---

<div class="header sl-header-custom">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="top-nav sl-hidden md:sl-flex" aria-label="Main navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={['top-nav-link', { active: isActive(link.href) }]}
      >
        {link.label}
      </a>
    ))}
  </nav>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style>
  .sl-header-custom {
    display: flex;
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    /* Override Starlight's overflow: clip so dropdown can escape */
    overflow: visible !important;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .top-nav {
    gap: 0.25rem;
    align-items: center;
  }

  .top-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .top-nav-link:hover {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }

  .top-nav-link.active {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .sl-header-custom {
      display: flex;
      align-items: center;
      gap: var(--sl-nav-gap);
    }
  }
</style>
