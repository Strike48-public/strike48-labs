---
import logo from "../assets/strike48-logo-light.svg";

interface Props {
  title?: string;
  tagline?: string;
}

const { title = "Strike48", tagline = "Desktop shell & connector platform" } = Astro.props;
---

<section class="landing-hero">
  <img src={logo.src} alt="Strike48" height="48" style="margin: 0 auto 1.5rem; display: block;" />
  <p class="tagline">{tagline}</p>
  <div class="cta-group">
    <a href="/strikehub/getting-started/" class="cta-primary">Get Started</a>
    <a href="/overview/" class="cta-secondary">Read the Docs</a>
  </div>
</section>
