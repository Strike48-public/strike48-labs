---
interface Props {
  title?: string;
  tagline?: string;
}

const { title = "Strike48", tagline = "Desktop shell & connector platform" } = Astro.props;
---

<section class="landing-hero">
  <img src="/favicon.svg" alt="Strike48" width="72" height="72" style="margin: 0 auto 1.5rem;" />
  <h1>{title}</h1>
  <p class="tagline">{tagline}</p>
  <div class="cta-group">
    <a href="/docs/strikehub/getting-started/" class="cta-primary">Get Started</a>
    <a href="/overview/" class="cta-secondary">Read the Docs</a>
  </div>
</section>
