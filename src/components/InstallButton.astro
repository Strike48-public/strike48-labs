---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  href: string;
  label?: string;
}

const { href, label = "Install" } = Astro.props;
---

<a href={href} class="btn btn-primary gap-2.5 mt-5 mb-2 no-underline group relative overflow-hidden">
  <span class="install-shimmer"></span>
  <span class="opacity-85">
    <LucideIcon name="download" size={18} />
  </span>
  <span class="relative z-[1]">{label}</span>
  <span class="opacity-0 -translate-x-1 group-hover:opacity-85 group-hover:translate-x-0 transition-all duration-200 flex items-center">
    <LucideIcon name="arrow-right" size={16} />
  </span>
</a>

<style>
  .install-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in srgb, var(--color-primary-content) 12%, transparent) 45%,
      color-mix(in srgb, var(--color-primary-content) 18%, transparent) 50%,
      color-mix(in srgb, var(--color-primary-content) 12%, transparent) 55%,
      transparent 70%
    );
    transform: translateX(-100%);
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .group:hover .install-shimmer {
    transform: translateX(100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .install-shimmer {
      display: none;
    }
  }
</style>
