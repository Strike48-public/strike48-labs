---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  href: string;
  label?: string;
}

const { href, label = "Install" } = Astro.props;
---

<a href={href} class="install-btn">
  <span class="install-btn-icon">
    <LucideIcon name="download" size={18} />
  </span>
  <span class="install-btn-label">{label}</span>
  <span class="install-btn-arrow">
    <LucideIcon name="arrow-right" size={16} />
  </span>
</a>

<style>
  .install-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1.5rem;
    margin: 1.25rem 0 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    color: #fff;
    background: var(--strike-blue, #2563eb);
    border-radius: 0.5rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Shimmer overlay */
  .install-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.12) 45%,
      rgba(255, 255, 255, 0.18) 50%,
      rgba(255, 255, 255, 0.12) 55%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .install-btn:hover {
    transform: translateY(-1px);
    box-shadow:
      0 4px 16px rgba(37, 99, 235, 0.35),
      0 0 0 1px rgba(37, 99, 235, 0.15);
  }

  .install-btn:hover::before {
    transform: translateX(100%);
  }

  .install-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
  }

  .install-btn-icon {
    display: flex;
    align-items: center;
    opacity: 0.85;
  }

  .install-btn-label {
    position: relative;
    z-index: 1;
  }

  .install-btn-arrow {
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .install-btn:hover .install-btn-arrow {
    opacity: 0.85;
    transform: translateX(0);
  }

  /* Dark mode */
  :root[data-theme="dark"] .install-btn {
    background: #2563eb;
  }

  :root[data-theme="dark"] .install-btn:hover {
    box-shadow:
      0 4px 20px rgba(96, 165, 250, 0.3),
      0 0 0 1px rgba(96, 165, 250, 0.2);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .install-btn,
    .install-btn::before,
    .install-btn-arrow {
      transition: none !important;
      transform: none !important;
    }

    .install-btn-arrow {
      opacity: 0.85;
    }
  }
</style>
