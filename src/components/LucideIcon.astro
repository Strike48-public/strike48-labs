---
import fs from "node:fs";
import path from "node:path";

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;

const iconPath = path.resolve(
  `node_modules/lucide-static/icons/${name}.svg`
);
let svg = "";
try {
  svg = fs.readFileSync(iconPath, "utf-8");
  svg = svg
    .replace(/width="24"/, `width="${size}"`)
    .replace(/height="24"/, `height="${size}"`);
  if (className) {
    svg = svg.replace(/class="[^"]*"/, `class="${className}"`);
  }
} catch {
  svg = `<!-- icon "${name}" not found -->`;
}
---

<Fragment set:html={svg} />
