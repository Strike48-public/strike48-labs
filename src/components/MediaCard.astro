---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  title: string;
  description: string;
  iconName: string;
  status?: "coming-soon" | "available";
  mediaSrc?: string;
  mediaType?: "image" | "video";
}

const {
  title,
  description,
  iconName,
  status = "coming-soon",
  mediaSrc,
  mediaType = "image",
} = Astro.props;
---

<div class="card bg-base-200 border border-base-content/10 overflow-hidden hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5 transition-all duration-200">
  {status === "available" && mediaSrc ? (
    <figure>
      {mediaType === "video" ? (
        <video src={mediaSrc} controls preload="metadata" class="w-full" />
      ) : (
        <img src={mediaSrc} alt={title} loading="lazy" class="w-full" />
      )}
    </figure>
  ) : (
    <figure class="bg-gradient-to-br from-primary/30 to-primary/60 py-12 px-8">
      <div class="flex flex-col items-center gap-3 text-primary-content/80">
        <LucideIcon name={iconName} size={48} />
        <span class="badge badge-warning badge-sm text-xs font-semibold uppercase tracking-wide">Coming Soon</span>
      </div>
    </figure>
  )}
  <div class="card-body p-5 gap-1">
    <h3 class="card-title text-base">{title}</h3>
    <p class="text-sm text-base-content/60 leading-relaxed">{description}</p>
  </div>
</div>
