---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  title: string;
  description: string;
  iconName: string;
  status?: "coming-soon" | "available";
  mediaSrc?: string;
  mediaType?: "image" | "video";
}

const {
  title,
  description,
  iconName,
  status = "coming-soon",
  mediaSrc,
  mediaType = "image",
} = Astro.props;
---

<div class="media-card">
  {status === "available" && mediaSrc ? (
    <div class="media-preview">
      {mediaType === "video" ? (
        <video src={mediaSrc} controls preload="metadata" />
      ) : (
        <img src={mediaSrc} alt={title} loading="lazy" />
      )}
    </div>
  ) : (
    <div class="media-placeholder">
      <LucideIcon name={iconName} size={48} />
      <span class="coming-soon-badge">Coming Soon</span>
    </div>
  )}
  <div class="media-info">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
  .media-card {
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .media-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .media-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    color: #dbeafe;
  }

  .coming-soon-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    background: #efbf04;
    color: #0f172a;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .media-preview img,
  .media-preview video {
    width: 100%;
    display: block;
  }

  .media-info {
    padding: 1.25rem;
  }

  .media-info h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: #0f172a;
  }

  .media-info p {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.5;
    margin: 0;
  }

  @media (prefers-color-scheme: dark) {
    .media-card {
      border-color: #334155;
      background: #1e293b;
    }

    .media-card:hover {
      border-color: #60a5fa;
      box-shadow: 0 4px 12px rgba(96, 165, 250, 0.1);
    }

    .media-placeholder {
      background: linear-gradient(135deg, #172554 0%, #1e40af 100%);
    }

    .media-info h3 {
      color: #f1f5f9;
    }

    .media-info p {
      color: #94a3b8;
    }
  }
</style>
