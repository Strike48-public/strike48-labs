---
import LucideIcon from "./LucideIcon.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  iconName: string;
  badge?: string;
}

const { title, description, href, iconName, badge } = Astro.props;
---

<a href={href} class="card bg-base-200 border border-base-content/10 hover:border-primary/50 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/10 transition-all duration-300 no-underline group">
  <div class="card-body gap-3">
    <div class="w-11 h-11 rounded-lg bg-primary/15 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-primary-content group-hover:scale-105 transition-all duration-300">
      <LucideIcon name={iconName} size={24} />
    </div>
    <h3 class="card-title text-base-content text-lg">
      {title}
      {badge && <span class="badge badge-warning badge-sm text-xs">{badge}</span>}
    </h3>
    <p class="text-base-content/60 text-sm leading-relaxed m-0">{description}</p>
    <div class="card-actions justify-end mt-auto">
      <span class="text-primary opacity-0 group-hover:opacity-70 -translate-x-1 group-hover:translate-x-0 transition-all duration-200">
        <LucideIcon name="arrow-right" size={16} />
      </span>
    </div>
  </div>
</a>
