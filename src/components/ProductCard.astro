---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
}

const { title, description, href, icon, badge } = Astro.props;
---

<a href={href} class="product-card">
  <div class="product-icon">{icon}</div>
  <h3>
    {title}
    {badge && <span class="product-badge">{badge}</span>}
  </h3>
  <p>{description}</p>
</a>

<style>
  .product-card {
    display: block;
    padding: 2rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .product-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .product-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #0f172a;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .product-card p {
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .product-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    background: #efbf04;
    color: #0f172a;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (prefers-color-scheme: dark) {
    .product-card {
      border-color: #334155;
      background: #1e293b;
    }

    .product-card:hover {
      border-color: #60a5fa;
      box-shadow: 0 4px 12px rgba(96, 165, 250, 0.1);
    }

    .product-card h3 {
      color: #f1f5f9;
    }

    .product-card p {
      color: #94a3b8;
    }
  }
</style>
