---
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';
import LucideIcon from './LucideIcon.astro';

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;

const apps = [
  { name: 'Prospector Studio', href: '/prospector-studio/', icon: 'brain', description: 'AI orchestration platform' },
  { name: 'StrikeHub', href: '/strikehub/', icon: 'layout-dashboard', description: 'Unified desktop shell' },
  { name: 'KubeStudio', href: '/kubestudio/', icon: 'server', description: 'Kubernetes management' },
  { name: 'Pick', href: '/pick/', icon: 'shield-alert', description: 'Penetration testing toolkit' },
  { name: 'SDK for Rust', href: '/developers/sdk-rs/', icon: 'code', description: 'Build custom connectors' },
];
---

<div class="site-title-dropdown" id="app-switcher">
  <button
    class="site-title-trigger"
    aria-expanded="false"
    aria-haspopup="true"
    id="app-switcher-btn"
    type="button"
  >
    {
      config.logo && logos.dark && (
        <>
          <img
            class:list={{ 'light:sl-hidden print:hidden': !('src' in config.logo) }}
            alt={config.logo.alt}
            src={logos.dark.src}
            width={logos.dark.width}
            height={logos.dark.height}
          />
          {!('src' in config.logo) && (
            <img
              class="dark:sl-hidden print:block"
              alt={config.logo.alt}
              src={logos.light?.src}
              width={logos.light?.width}
              height={logos.light?.height}
            />
          )}
        </>
      )
    }
    <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate="no">
      {siteTitle}
    </span>
    <svg class="chevron-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div class="app-dropdown" id="app-dropdown" role="menu">
    <a href="/" class="app-dropdown-home" role="menuitem">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      Strike48 Home
    </a>
    <div class="app-dropdown-divider"></div>
    <div class="app-dropdown-header">Apps</div>
    {apps.map((app) => (
      <a href={app.href} class="app-dropdown-item" role="menuitem">
        <span class="app-dropdown-icon">
          <LucideIcon name={app.icon} size={18} />
        </span>
        <span class="app-dropdown-text">
          <span class="app-dropdown-name">{app.name}</span>
          <span class="app-dropdown-desc">{app.description}</span>
        </span>
      </a>
    ))}
    <div class="app-dropdown-divider"></div>
    <a href="/overview/" class="app-dropdown-footer-link" role="menuitem">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
      </svg>
      View all docs
    </a>
  </div>
</div>

<script is:inline>
  // Inline script runs immediately, no event listener needed
  (function () {
    var btn = document.getElementById('app-switcher-btn');
    var dropdown = document.getElementById('app-dropdown');
    if (!btn || !dropdown) return;

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    document.addEventListener('click', function (e) {
      if (!dropdown.contains(e.target) && !btn.contains(e.target)) {
        dropdown.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        dropdown.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
