---
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';
import LucideIcon from './LucideIcon.astro';

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;

const apps = [
  { name: 'Prospector Studio', href: '/prospector-studio/', icon: 'brain', description: 'AI orchestration platform' },
  { name: 'StrikeHub', href: '/strikehub/', icon: 'layout-dashboard', description: 'Unified desktop shell' },
  { name: 'KubeStudio', href: '/kubestudio/', icon: 'server', description: 'Kubernetes management' },
  { name: 'Pick', href: '/pick/', icon: 'shield-alert', description: 'Penetration testing toolkit' },
  { name: 'StrikeKit', href: '/developers/strikekit/', icon: 'terminal', description: 'Red team operations' },
  { name: 'SDK for Rust', href: '/developers/sdk-rs/', icon: 'code', description: 'Build custom connectors' },
];
---

<div class="dropdown" id="app-switcher">
  <div tabindex="0" role="button" class="flex items-center gap-2 cursor-pointer px-2 py-1 rounded-md hover:bg-base-content/5 transition-colors" id="app-switcher-btn">
    {
      config.logo && logos.dark && (
        <>
          <img
            class="logo-dark print:hidden"
            alt={config.logo.alt}
            src={logos.dark.src}
            width={logos.dark.width}
            height={logos.dark.height}
          />
          {!('src' in config.logo) && logos.light && (
            <img
              class="logo-light print:block"
              alt={config.logo.alt}
              src={logos.light.src}
              width={logos.light.width}
              height={logos.light.height}
            />
          )}
        </>
      )
    }
    <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate="no">
      {siteTitle}
    </span>
    <svg class="opacity-50 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>

  <div tabindex="0" class="dropdown-content menu bg-base-200 border border-base-content/10 rounded-box shadow-xl z-50 w-72 p-2 mt-2">
    <li>
      <a href="/" class="flex items-center gap-2 font-semibold text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Strike48 Home
      </a>
    </li>
    <li class="menu-title text-xs uppercase tracking-wider opacity-60">Apps</li>
    {apps.map((app) => (
      <li>
        <a href={app.href} class="flex items-center gap-3 py-2">
          <span class="flex items-center justify-center w-8 h-8 shrink-0 rounded-md bg-primary/15 text-primary">
            <LucideIcon name={app.icon} size={18} />
          </span>
          <span class="flex flex-col gap-0.5 min-w-0">
            <span class="text-sm font-semibold leading-tight">{app.name}</span>
            <span class="text-xs opacity-60 leading-snug">{app.description}</span>
          </span>
        </a>
      </li>
    ))}
    <div class="divider my-1"></div>
    <li>
      <a href="/overview/" class="text-sm opacity-60 hover:opacity-100 flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
        View all docs
      </a>
    </li>
  </div>
</div>

<style>
  .logo-dark,
  .logo-light {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: 0 50%;
  }

  /* Default: show dark logo, hide light */
  .logo-light {
    display: none;
  }

  /* When html has data-color-scheme="light", swap */
  :global([data-color-scheme="light"]) .logo-dark {
    display: none;
  }
  :global([data-color-scheme="light"]) .logo-light {
    display: block;
  }
</style>
