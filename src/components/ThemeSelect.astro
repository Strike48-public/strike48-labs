---
/**
 * daisyUI theme picker — shows all available themes with color swatches.
 * Replaces Starlight's built-in ThemeSelect.
 */

const themes = [
  'strike48',
  'strike48-light',
  'light',
  'dark',
  'cupcake',
  'bumblebee',
  'emerald',
  'corporate',
  'synthwave',
  'retro',
  'cyberpunk',
  'valentine',
  'halloween',
  'garden',
  'forest',
  'aqua',
  'lofi',
  'pastel',
  'fantasy',
  'wireframe',
  'black',
  'luxury',
  'dracula',
  'cmyk',
  'autumn',
  'business',
  'acid',
  'lemonade',
  'night',
  'coffee',
  'winter',
  'dim',
  'nord',
  'sunset',
  'caramellatte',
  'abyss',
  'silk',
];
---

<starlight-theme-select>
  <div class="dropdown dropdown-end">
    <div tabindex="0" role="button" class="btn btn-ghost btn-sm gap-1" aria-label="Select theme">
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path>
        <path d="M5 3v4"></path>
        <path d="M19 17v4"></path>
        <path d="M3 5h4"></path>
        <path d="M17 19h4"></path>
      </svg>
      <svg class="w-3 h-3 opacity-60" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
    <div tabindex="0" class="dropdown-content bg-base-200 border border-base-content/10 rounded-box shadow-2xl z-50 mt-2 p-3 w-56">
      <div class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-2 px-1">Theme</div>
      <div class="flex flex-col gap-1 max-h-80 overflow-y-auto overscroll-contain pr-1 theme-list">
        {themes.map((t) => (
          <button
            type="button"
            class="theme-option"
            data-theme-value={t}
            data-set-theme={t}
          >
            <div data-theme={t} class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-content/10 transition-colors cursor-pointer w-full">
              <div class="flex gap-0.5 shrink-0">
                <span class="w-2 h-4 rounded-sm bg-primary"></span>
                <span class="w-2 h-4 rounded-sm bg-secondary"></span>
                <span class="w-2 h-4 rounded-sm bg-accent"></span>
                <span class="w-2 h-4 rounded-sm bg-neutral"></span>
              </div>
              <span class="text-sm font-medium text-base-content flex-1 text-left">{t}</span>
              <svg class="check-icon w-4 h-4 text-primary shrink-0 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
          </button>
        ))}
      </div>
    </div>
  </div>
</starlight-theme-select>

<style>
  .theme-option {
    all: unset;
    display: block;
    width: 100%;
    cursor: pointer;
  }

  .theme-option.active .check-icon {
    display: block;
  }

  .theme-list {
    scrollbar-width: thin;
    scrollbar-color: var(--color-base-content) transparent;
  }
</style>

{/* Inlined to avoid FOUC */}
<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  const storageKey = 'starlight-theme';

  function loadTheme(): string {
    if (typeof localStorage === 'undefined') return 'strike48';
    return localStorage.getItem(storageKey) || 'strike48';
  }

  function applyTheme(theme: string): void {
    document.documentElement.dataset.theme = theme;
    document.documentElement.dataset.colorScheme =
      (window as any).StarlightThemeProvider?.lightThemes?.includes(theme) ? 'light' : 'dark';

    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, theme);
    }

    // Update active states
    document.querySelectorAll<HTMLButtonElement>('.theme-option').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.themeValue === theme);
    });
  }

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      applyTheme(loadTheme());
      this.querySelectorAll<HTMLButtonElement>('.theme-option').forEach((btn) => {
        btn.addEventListener('click', () => {
          applyTheme(btn.dataset.themeValue || 'strike48');
          // Close the dropdown
          (document.activeElement as HTMLElement)?.blur();
        });
      });
    }
  }
  customElements.define('starlight-theme-select', StarlightThemeSelect);
</script>
