---
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/landing.css";

const features = [
  {
    iconName: "plug",
    title: "Connector Architecture",
    description:
      "Modular connector system — each tool runs as an isolated process with its own UI, communicating over IPC.",
  },
  {
    iconName: "lock",
    title: "Secure by Default",
    description:
      "Unix domain sockets for process isolation. OIDC authentication with automatic token injection. No ports exposed.",
  },
  {
    iconName: "zap",
    title: "Native Performance",
    description:
      "Built with Rust and Dioxus for sub-2-second startup. WebView rendering with minimal memory overhead.",
  },
  {
    iconName: "app-window",
    title: "Single Window",
    description:
      "All your Strike48 connectors in one native window. Switch between tools without alt-tabbing.",
  },
  {
    iconName: "sparkles",
    title: "AI-Powered with Prospector Studio",
    description:
      "Autonomous agents, RAG-enabled knowledge bases, and multi-step workflows — automate reconnaissance, analysis, and reporting with AI.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Strike48 Labs</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap");
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "Inter", system-ui, sans-serif;
        color: #0f172a;
        background: #fff;
        color-scheme: light;
      }
    </style>
  </head>
  <body>
    <CookieConsent />
    <Hero
      tagline="Documentation for the Strike48 security platform. Desktop connector apps for end users, and SDKs for building custom tools and connectors."
    />

    <section class="products-section">
      <h2>For End Users</h2>
      <div class="products-grid">
        <ProductCard
          title="Prospector Studio"
          description="AI-powered workflow automation and agent platform."
          href="/prospector-studio/"
          iconName="bot"
          imageSrc="/img/prospector-studio/screenshots/overview.png"
        />
        <ProductCard
          title="StrikeHub"
          description="The unified desktop shell."
          href="/strikehub/"
          iconName="layout-dashboard"
          imageSrc="/img/strikehub/screenshots/overview.png"
        />
        <ProductCard
          title="KubeStudio"
          description="Kubernetes cluster management dashboard."
          href="/kubestudio/"
          iconName="server"
          imageSrc="/img/kubestudio/screenshots/overview.png"
        />
        <ProductCard
          title="Pick"
          description="Headless penetration testing toolkit."
          href="/pick/"
          iconName="shield-alert"
          imageSrc="/img/pick/screenshots/overview.png"
        />
      </div>
    </section>

    <section class="products-section">
      <h2>For Developers</h2>
      <div class="products-grid">
        <ProductCard
          title="Prospector Studio API"
          description="GraphQL API reference for integrators and connector developers."
          href="/developers/prospector-studio/graphql-api/"
          iconName="braces"
        />
        <ProductCard
          title="SDK for Rust"
          description="Build powerful, type-safe connectors with the Strike48 SDK."
          href="/developers/sdk-rs/"
          iconName="code"
        />
      </div>
    </section>

    <FeatureGrid features={features} />

    <section class="cta-section">
      <h2>Ready to get started?</h2>
      <p>Set up StrikeHub and start managing your connector apps in one place.</p>
      <div class="cta-group">
        <a href="/strikehub/getting-started/" class="cta-primary">
          Quick Start Guide
        </a>
        <a href="/overview/" class="cta-secondary">
          Browse Documentation
        </a>
      </div>
    </section>

  </body>
</html>
